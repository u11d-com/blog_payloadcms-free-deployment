# Database connection string - MongoDB Cloud
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/blog-db?retryWrites=true&w=majority

# Used to encrypt JWT tokens - Generate a random 48-character hex string
# Store in AWS Secrets Manager, do NOT commit to git
PAYLOAD_SECRET=your-secure-48-character-hex-string-here

# Used to configure CORS, format links and more. No trailing slash
# On Amplify: https://your-app-id.amplifyapp.com
# For local development: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs - Generate a random 48-character hex string
# Store in AWS Secrets Manager, do NOT commit to git
CRON_SECRET=your-secure-48-character-hex-string-here

# Used to validate preview requests - Generate a random 48-character hex string
# Store in AWS Secrets Manager, do NOT commit to git
PREVIEW_SECRET=your-secure-48-character-hex-string-here

# AWS S3 configuration for media storage
# These exact names are required by Payload config and Amplify build env export
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-iam-user-access-key
S3_SECRET_ACCESS_KEY=your-iam-user-secret-key
S3_BUCKET=your-blog-bucket-name
